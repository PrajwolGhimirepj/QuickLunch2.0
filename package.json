{
  "name": "quicklunch",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",

  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "server": "node Server.js",
    "start": "concurrently \"npm run server\" \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },

  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "firebase": "^12.11.0",
    "koffi": "^2.16.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "ws": "^8.20.0"
  },

  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },

  "build": {
    "appId": "com.prajwol.quicklunch",
    "productName": "QuickLunch",

    "asar": false,

    "directories": {
      "output": "release"
    },

    "files": [
      "**/*"
    ],

    "extraResources": [
      {
        "from": "./scripts",
        "to": "scripts"
      }
    ],

    "win": {
      "target": "nsis",
      "artifactName": "${productName}-Setup.${ext}"
    }
  }
}